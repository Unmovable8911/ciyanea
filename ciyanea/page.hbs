{{!< default}}

{{!--
  Static page (e.g. About).

  A full-width centered single column with NO sidebar — distinct from the
  homepage's two-column layout. Suited to long-form static content. The page
  body is rendered through Ghost's {{content}} helper so Koenig cards (wide/full
  width images, etc.) render correctly.
--}}

{{#page}}
<article class="page">
    {{!-- Honour the editor's "Show title and feature image" toggle
          (@page.show_title_and_feature_image). When off, render the body only. --}}
    {{#if @page.show_title_and_feature_image}}
    <header class="page-header">
        <h1 class="page-title">{{title}}</h1>
        {{#if feature_image}}
            <figure class="page-feature-image">
                <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" />
            </figure>
        {{/if}}
    </header>
    {{/if}}

    <section class="page-content">
        {{content}}
    </section>
</article>
{{/page}}
