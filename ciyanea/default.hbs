<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{{meta_title}}</title>

    {{!-- Fonts: Playfair Display (headings) + Inter (body) --}}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
    />

    {{!-- Theme styles + design tokens --}}
    <link rel="stylesheet" type="text/css" href="{{asset "css/screen.css"}}" />

    {{ghost_head}}
</head>

<body class="{{body_class}}" data-content-api-key="{{@custom.content_api_key}}">
    <div class="site">
        <header class="site-header">
            <div class="site-header-inner">
                {{!-- Left group: logo + navigation. --}}
                <div class="site-header-left">
                    <a class="site-logo" href="{{@site.url}}">
                        {{#if @site.logo}}
                            <img src="{{@site.logo}}" alt="{{@site.title}}" />
                        {{else}}
                            {{@site.title}}
                        {{/if}}
                    </a>

                    {{!-- The hamburger collapses the nav on narrow screens
                          (issue 06). CSS hides the button at desktop widths and
                          keeps the nav inline; below 768px the button shows and
                          the nav becomes a toggled panel driven by nav-menu.js.
                          The search control + language switcher stay in the bar
                          (they live in the right group, untouched here). --}}
                    <div class="site-nav-menu" data-nav-menu>
                        <button
                            type="button"
                            class="site-nav-toggle"
                            aria-label="{{t "Menu"}}"
                            aria-haspopup="true"
                            aria-expanded="false"
                            data-nav-toggle
                        >
                            <span class="site-nav-toggle-bars" aria-hidden="true"></span>
                        </button>

                        <nav class="site-nav" aria-label="{{t "Main navigation"}}" hidden data-nav-panel>
                            {{> navigation}}
                        </nav>
                    </div>
                </div>

                {{!-- Right group: search affordance + language switcher.
                      The search control opens Ghost's built-in sodo-search
                      overlay; the language switcher stays rightmost. --}}
                <div class="site-header-right">
                    <div class="site-search" data-site-search>
                        {{> search}}
                    </div>

                    {{> language-switcher}}
                </div>
            </div>
        </header>

        <main class="site-main" role="main">
            {{{body}}}
        </main>

        <footer class="site-footer">
            <div class="site-footer-inner">
                <p class="site-footer-copyright">
                    &copy; {{date format="YYYY"}} {{@site.title}}
                </p>
            </div>
        </footer>
    </div>

    {{!-- Global: language switcher dropdown + current-language resolution. --}}
    <script src="{{asset "js/lang-switcher.js"}}"></script>

    {{!-- Global: highlight the nav item for the current section (Home / Micro). --}}
    <script src="{{asset "js/active-section.js"}}"></script>

    {{!-- Global: collapse the nav behind a hamburger on narrow screens. --}}
    <script src="{{asset "js/nav-menu.js"}}"></script>

    {{ghost_foot}}
</body>
</html>
