{{!--
  Hero carousel for the homepage.

  Queries up to five FEATURED posts in the current language. The homepage wrapper
  template (index-<code>.hbs) passes lang="hash-<code>" — the language's internal
  tag slug — down through partials/home.hbs to here; the {{#get}} filter scopes the
  featured query to it. The whole region is wrapped in {{#if posts}}, so when there
  are no featured posts the hero renders nothing at all.

  Each slide shows the large cover image, the first PUBLIC tag, the title, an
  excerpt, and the author. hero.js (loaded by index.hbs) handles 5-second
  auto-advance, the previous/next arrows, and the clickable dot indicators.
--}}
{{#get "posts" filter="featured:true+tag:{{lang}}" limit="5" include="authors,tags"}}
    {{#if posts}}
        <section class="hero" aria-label="{{t "Featured"}}" data-hero>
            <div class="hero-viewport">
                <div class="hero-track" data-hero-track>
                    {{#foreach posts}}
                        <article class="hero-slide" data-hero-slide aria-roledescription="slide">
                            <a class="hero-slide-link" href="{{url}}">
                                {{#if feature_image}}
                                    <img
                                        class="hero-slide-image"
                                        src="{{img_url feature_image size="xl"}}"
                                        srcset="{{img_url feature_image size="l"}} 960w, {{img_url feature_image size="xl"}} 1200w"
                                        sizes="100vw"
                                        alt="{{title}}"
                                        loading="lazy"
                                    />
                                {{/if}}
                                <div class="hero-slide-overlay">
                                    {{#primary_tag}}
                                        <span class="hero-slide-tag">{{name}}</span>
                                    {{/primary_tag}}

                                    <h2 class="hero-slide-title">{{title}}</h2>

                                    {{#if custom_excerpt}}
                                        <p class="hero-slide-excerpt">{{custom_excerpt}}</p>
                                    {{else}}
                                        <p class="hero-slide-excerpt">{{excerpt words="30"}}</p>
                                    {{/if}}

                                    {{#primary_author}}
                                        <div class="hero-slide-author">
                                            {{#if profile_image}}
                                                <img class="hero-slide-author-avatar" src="{{img_url profile_image size="xs"}}" alt="{{name}}" loading="lazy" />
                                            {{/if}}
                                            <span class="hero-slide-author-name">{{name}}</span>
                                        </div>
                                    {{/primary_author}}
                                </div>
                            </a>
                        </article>
                    {{/foreach}}
                </div>
            </div>

            <button class="hero-arrow hero-arrow-prev" type="button" data-hero-prev aria-label="{{t "Previous"}}">
                &larr;
            </button>
            <button class="hero-arrow hero-arrow-next" type="button" data-hero-next aria-label="{{t "Next"}}">
                &rarr;
            </button>

            <div class="hero-dots" data-hero-dots role="tablist" aria-label="{{t "Featured"}}"></div>
        </section>
    {{/if}}
{{/get}}
