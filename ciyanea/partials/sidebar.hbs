{{!--
  Context-aware sidebar.

  ARTICLE branch ({{#if post}}): a table-of-contents container that toc.js
  populates from the rendered article's h2/h3 headings, plus a featured-posts
  block of up to 3 posts excluding the current one (filter featured:true+id:-<id>).

  HOMEPAGE branch: a preview of the most recent micro-post for the current
  language, a language-relative "view all micro-posts" link, and a popular-tags
  block. TAG-PAGE branch: the popular-tags block only — the micro preview is
  scoped to the homepage.

  The recent micro-post preview needs the current language: the homepage wrapper
  (index-<code>.hbs) passes lang="hash-<code>" through partials/home.hbs into this
  partial as {{lang}}. It is guarded by {{#if lang}} so it renders ONLY on the
  homepage (on tag/article pages {{lang}} is absent and the language micro query is
  not meaningful). The popular-tags block (below) is context-independent and renders
  on the homepage, tag pages, and article pages.

  On the homepage the recent micro-post is fetched with the SAME query as the
  micro feed, limited to one: filter tag:<lang>+tag:hash-micro, limit=1, page=1.
  It is rendered through the micro-card partial so the preview matches the stream
  presentation, and micro-feed.js (loaded on the homepage) wires the identical
  expand/collapse behavior onto it via the shared [data-micro-card] hook.
--}}
{{#if post}}
<aside class="article-sidebar" aria-label="{{t "Sidebar"}}">

    {{!-- Table of contents. toc.js fills [data-toc] from the article's h2/h3
          headings and hides this block when the article has none. --}}
    <section class="sidebar-block sidebar-toc" aria-label="{{t "Table of contents"}}">
        <h2 class="sidebar-heading">{{t "Table of contents"}}</h2>
        <nav class="sidebar-toc-nav" data-toc></nav>
    </section>

    {{!-- Featured posts: up to 3, excluding the current article. --}}
    <section class="sidebar-block sidebar-featured" aria-label="{{t "Featured posts"}}">
        <h2 class="sidebar-heading">{{t "Featured posts"}}</h2>

        {{#get "posts" filter="featured:true+id:-{{id}}" limit="3"}}
            {{#if posts}}
                <ul class="sidebar-featured-list">
                    {{#foreach posts}}
                        <li class="sidebar-featured-item">
                            <a class="sidebar-featured-link" href="{{url}}">{{title}}</a>
                        </li>
                    {{/foreach}}
                </ul>
            {{else}}
                <p class="sidebar-empty">{{t "No featured posts yet."}}</p>
            {{/if}}
        {{/get}}
    </section>

</aside>
{{else}}
<aside class="home-sidebar" aria-label="{{t "Sidebar"}}">

    {{!-- Recent micro-post preview — homepage only. Guarded by {{#if lang}}: the
          homepage wrapper passes lang="hash-<code>", tag pages do not. (Custom
          language collections don't carry the "index" context, so {{#is "index"}}
          can't be used here.) --}}
    {{#if lang}}
    <section class="sidebar-block sidebar-micro" aria-label="{{t "Recent micro-post"}}">
        <h2 class="sidebar-heading">{{t "Latest micro-post"}}</h2>

        {{#get "posts" filter="tag:{{lang}}+tag:hash-micro" limit="1" page="1"}}
            {{#foreach posts}}
                {{> "micro-card"}}
            {{else}}
                <p class="sidebar-empty">{{t "No micro-posts yet."}}</p>
            {{/foreach}}
        {{/get}}

        {{!-- Language-relative link: lang-switcher.js rewrites data-lang-href
              into /<code>/micro/ for the active language. --}}
        <a class="sidebar-micro-all" href="#" data-lang-href="micro/">
            {{t "View all micro-posts"}} &rarr;
        </a>
    </section>
    {{/if}}

    {{!-- Popular tags. Public tags only (internal hash- language/micro tags are
          not browsable topics); each entry links to its /tag/<slug>/ page. --}}
    <section class="sidebar-block sidebar-tags popular-tags" aria-label="{{t "Popular tags"}}">
        <h2 class="sidebar-heading">{{t "Popular tags"}}</h2>

        {{#get "tags" filter="visibility:public" limit="10" order="count.posts desc" include="count.posts"}}
            {{#if tags}}
                <ul class="popular-tags-list">
                    {{#foreach tags}}
                        <li class="popular-tags-item">
                            <a class="popular-tags-link" href="{{url}}">{{name}}</a>
                        </li>
                    {{/foreach}}
                </ul>
            {{else}}
                <p class="sidebar-empty">{{t "No tags yet."}}</p>
            {{/if}}
        {{/get}}
    </section>

</aside>
{{/if}}
